#!/bin/bash
# Set environment for using these scripts with OCT
# Customize for the directories on your system
export MODELICA_BUILDINGS_LIB=/opt/modelica-buildings
export MODELICAPATH=/opt/OCT/ThirdParty/MSL:${MODELICA_BUILDINGS_LIB}:.:..
export MODELON_LICENSE_PATH=/opt/OCT/Licenses/NodeLocked
export PATH=$PATH:$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )
export PYTHONPATH=$PYTHONPATH:/opt/OCT/Python
