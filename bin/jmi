#!/bin/bash
# Set up environment for JModelica and runs passed Python script
# Assumes jm_ipython.sh such as in JModelica/bin is on your PATH
# Place a custom version of this early in your PATH
unset _JAVA_OPTIONS # Fedora needs this
export MODELICA_BUILDINGS_LIB=/Projects/EnergyPlus/SOEP/tst/modelica-buildings
script_py=$(which "$1")
if [ "$script_py" == "" ]; then
    echo "$1 not found on your PATH"
else
    shift
    jm_ipython.sh $script_py "$@"
fi
