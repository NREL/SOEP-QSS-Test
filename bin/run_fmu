#!/bin/bash
# Run the local model FMU with PyFMI
# jm script customized for your system must be on your PATH
# run_fmu.py must be on your PATH
# Run from the modeling tool directory or below such as MyModel/JModelica/out

# Find tool name and dir
tool_dir=$(realpath $(pwd))
tool=$(basename "$tool_dir")
while [ "$tool" != "Dymola" ] && [ "$tool" != "JModelica" ] && [ "$tool" != "Ptolemy" ] && [ "$tool" != "QSS" ]; do
    tool_dir=$(dirname "$tool_dir")
    tool=$(basename "$tool_dir")
    if [ "$tool_dir" == "/" ]; then
        tool_dir=""
        break
    fi
done

# Find model name and dir
model_dir=$(dirname "$tool_dir")
model=$(basename "$model_dir")

# Run the simulation with PyFMI
run_fmu=$(which "run_fmu.py")
if [ "$run_fmu" == "" ]; then
    echo "run_fmu.py not found on your PATH"
else
    if [ -e "$model_dir/$model.var" ]; then # Use variable list
        jm $run_fmu $tool_dir/$model.fmu --var $model_dir/$model.var $@
    elif [ -e "$tool_dir/$model.fmu" ]; then # No variable list
        jm $run_fmu $tool_dir/$model.fmu $@
    else # No FMU
        jm $run_fmu $@
    fi
fi
